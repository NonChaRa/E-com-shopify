# ============================================================
# ASTÉRI 2K STUDIO — Client Environment Variables
# Copy this file to .env.local and fill in your own values.
# Never commit .env.local to version control.
# ============================================================

# ---- Shopify Storefront API --------------------------------
# Found in: Shopify Admin → Apps → Develop apps → your app → API credentials
VITE_SHOPIFY_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_ACCESS_TOKEN=your_storefront_access_token

# Shopify Headless OAuth (used for customer account login)
VITE_SHOPIFY_CLIENT_ID=your_shopify_client_id
VITE_SHOPIFY_ACCOUNT_DOMAIN=account.your-store.myshopify.com
VITE_SHOPIFY_REDIRECT_URI=https://your-domain.com/callback

# ---- Supabase ---------------------------------------------
# Found in: Supabase Dashboard → Project Settings → API
# Use the anon/public key (safe to expose in the browser)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ---- Internal API (AdminPanel) ----------------------------
# URL of the Express/Node backend. Defaults to http://localhost:5000 in dev.
VITE_API_URL=https://your-api-domain.com
